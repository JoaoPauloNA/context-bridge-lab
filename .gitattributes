# Normalização de fim de linha (evita arquivos "achatados" e diffs por CRLF/LF)
* text=auto eol=lf

# Scripts e código que exigem LF
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Arquivos específicos de Windows: CRLF
*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binários (sem conversão)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
